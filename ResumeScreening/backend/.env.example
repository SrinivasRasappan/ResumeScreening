# Anthropic Configuration
# Set your Anthropic API key here (required for real requests)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# If you want to run the server without a key, set DRY_RUN=true.
# DRY_RUN=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost", "http://127.0.0.1"]
